# =============================================================================
# Copie este archivo como ".env" en la raíz del proyecto y rellene los valores.
# Nunca suba ".env" al repositorio (contiene secretos).
# =============================================================================

# --- Django general ---
# SECRET_KEY=...   # Obligatorio en producción (generar una clave larga y aleatoria)
# DEBUG=False
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,tu-dominio.com

# --- Base de datos PostgreSQL ---
POSTGRES_DB=paredes_bienes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Correo (todo desde variables; sin credenciales fijas en código) ---
# Si no define EMAIL_HOST, el sistema usa un backend de consola silencioso (desarrollo).
#
# Gmail (TLS, puerto 587):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
#
# Outlook / Microsoft 365 (habilitar SMTP AUTH en el administrador):
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
#
# Yahoo (SSL implícito, puerto 465):
# EMAIL_HOST=smtp.mail.yahoo.com
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
#
# Hosting / correo corporativo (ajustar según su proveedor):
# EMAIL_HOST=mail.suempresa.com.sv
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
#
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Remitente de recibos (From). Recomendación: déjelo vacío para que coincida con EMAIL_HOST_USER
# (muchas veces el hosting exige la misma cuenta que autentica en SMTP).
# Si lo define, use el mismo correo que EMAIL_HOST_USER o uno autorizado por su proveedor.
# DEFAULT_FROM_EMAIL=
# Nombre visible si DEFAULT_FROM_EMAIL está vacío y se usa EMAIL_HOST_USER:
# DEFAULT_FROM_EMAIL_NAME=Paredes Bienes Raíces
#
# Opcional: correo para avisos del sistema a usted (errores 500, etc.). No sustituye SMTP.
# ADMIN_EMAIL=
# ADMIN_NAME=Administrador del sistema
#
# Opcional: remitente técnico para esos avisos (por defecto = EMAIL_HOST_USER).
# SERVER_EMAIL=

# Opcional: forzar backend (SendGrid, SES, Mailgun, etc. documentan el valor exacto)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Desarrollo: volcado completo del correo en consola (MIME)
# EMAIL_FULL_CONSOLE=0

# Recibos por correo al cliente (1=activo)
RECIBO_ENVIAR_EMAIL=1
# RECIBO_EMAIL_ASUNTO=Su recibo de pago — Paredes Bienes Raíces

# URL pública del sitio (sin barra final). Use HTTPS en producción.
# En el mensaje de WhatsApp (wa.me) puede ser http o https para el enlace de descarga.
# Twilio y el envío de documentos por URL en Meta exigen HTTPS accesible desde internet.
# PUBLIC_BASE_URL=https://su-dominio.com

# Prefijo país para armar el número en wa.me (El Salvador = 503)
# RECIBO_WHATSAPP_PAIS=503

# --- WhatsApp: PDF automático (el enlace wa.me del navegador NUNCA adjunta archivos) ---
#
# Opción A — Meta WhatsApp Cloud API (recomendado: sube el PDF a Meta, no hace falta PUBLIC_BASE_URL)
# WHATSAPP_CLOUD_ENABLED=1
# RECIBO_ENVIAR_WHATSAPP_META=1
# WHATSAPP_CLOUD_ACCESS_TOKEN=su_token_largo
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=id_del_numero
# WHATSAPP_CLOUD_API_VERSION=v21.0
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=token_aleatorio_webhook
# Tamaño máximo del PDF para Meta (bytes; por defecto 100 MB, límite orientativo de WhatsApp)
# WHATSAPP_MAX_PDF_BYTES=104857600
#
# Si usa document.link: la URL debe ser HTTPS y el host alcanzable desde internet (no localhost).
# /media/... debe servirse con Content-Type: application/pdf (p. ej. en Nginx).
# Alternativa de seguridad: URL firmada (S3/GCS) con caducidad corta en lugar de PDF público permanente.
#
# Opción B — Twilio WhatsApp (requiere PUBLIC_BASE_URL HTTPS y que /media/... sea público)
# RECIBO_ENVIAR_WHATSAPP_TWILIO=1
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Railway (https://railway.com) — definir en el panel Variables, no en el repo ---
# Al conectar PostgreSQL, Railway crea DATABASE_URL; no hace falta POSTGRES_* sueltas.
# SECRET_KEY=   (generar cadena larga aleatoria)
# DEBUG=False
# DJANGO_ALLOWED_HOSTS=tu-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://tu-app.up.railway.app
# PUBLIC_BASE_URL=https://tu-app.up.railway.app
# EMAIL_* según su proveedor de correo
